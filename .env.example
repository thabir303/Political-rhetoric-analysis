# Application Settings
APP_NAME=RAG-IR API
APP_VERSION=1.0.0
ENVIRONMENT=development  # Change to 'production' on Render

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db  # Change to '/data/chroma_db' on Render
CHROMA_COLLECTION_NAME=articles

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8000  # Add Vercel URL on Render

# Authentication Configuration
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-admin-password
JWT_SECRET=your-jwt-secret-key  # Generate NEW strong secret for Render!
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano
